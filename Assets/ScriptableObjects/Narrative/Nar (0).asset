  m_Name: Nar (0)
  m_EditorClassIdentifier: 
  nodes:
  - nodeId: 0
    text: "Odense, sommeren 1943.\n\r\nBes\xE6ttelsen har \xE6ndret sig.\r\nDet er
      ikke l\xE6ngere stille.\n\r\nStrejker. Sabotage. Rygter.\n\nOg England kaster
      forsyninger ned fra himlen. \n\r\nDu er ikke l\xE6ngere bare en tilskuer.\nDu
      er en del af modstandsbev\xE6gelsen.\n\r\nOg i aften\u2026 venter en besked
      fra BBC.\r"
    choices: []
    defaultTargetNodeId: 1
    minigamePrefab: {fileID: 0}
  - nodeId: 1
    text: "Klokken er 18:15.\n\r\nDig og din ven Erik sidder og lytter ved radioen.\n\r\nRadioen
      knitrer.\n\r\n\u201CEn hilsen til Niels.\r\n Bageren arbejder i nat.\u201D\n\r\nErik
      vender sig mod dig.\n\r\n\u201CDet er vores besked, f\xE5 afkodet den\u201D\r"
    choices:
    - id: 1
      label: "Tyskerne er t\xE6t"
      targetNodeId: 1
    - id: 1
      label: Nedkastning i na
      targetNodeId: 1
    - id: 1
      label: Forbered jer
      targetNodeId: 1
    - id: 1
      label: Nedkastning i nat
      targetNodeId: 2
    defaultTargetNodeId: 1
    minigamePrefab: {fileID: 7416240185725632505, guid: 6a1ce9beeea46de438ece10a53cdffb5, type: 3}
  - nodeId: 2
    text: "I ankommer til kysten ved Eneb\xE6rodde.\n\nAlt er m\xF8rkt.\n\nFolk st\xE5r
      allerede klar.\n\nErik kigger p\xE5 dig.\n\n\u201CV\xE6r klar med lygten, n\xE5r
      vi h\xF8rer flyet\u201D\r"
    choices: []
    defaultTargetNodeId: 3
    minigamePrefab: {fileID: 7416240185725632505, guid: 63581926aea032c46943b25ac5c3de79, type: 3}
  - nodeId: 3
    text: "En times tid senere er folk begyndt at blive ansp\xE6ndte.\_\n\nS\xE5
      h\xF8res det.\n\nEt fly.\n\nEn britisk Stirling flyver lavt hen over jer.\n\n\u201CSkynd
      dig at morse til flyet\u201D r\xE5ber Erik.\"\r"
    choices: []
    defaultTargetNodeId: 3
    minigamePrefab: {fileID: 0}
