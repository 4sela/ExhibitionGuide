%YAML 1.1
%TAG !u! tag:unity3d.com,2011:
--- !u!114 &11400000
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 0}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 234500c0ac766e04999bbcf9fc22fb4d, type: 3}
  m_Name: Nar (0)
  m_EditorClassIdentifier: 
  nodes:
  - nodeId: 0
    text: "Odense, sommeren 1943.\n\r\nBes\xE6ttelsen har \xE6ndret sig.\n\r\nDet
      er ikke l\xE6ngere stille.\n\r\nStrejker. Sabotage. Rygter.\n\r\nOg England
      kaster forsyninger ned fra himlen. \n\r\nDu er ikke l\xE6ngere bare en tilskuer.\n\r\nDu
      er en del af modstandsbev\xE6gelsen.\r\n\r"
    choices: []
    defaultTargetNodeId: 1
    voiceClip: {fileID: 8300000, guid: 5e9d80c58c2582e47a8c48d9864e7b86, type: 3}
    BackgroundImage: {fileID: 2800000, guid: 5b5c6e1d9fcc8884784a77d0e539413e, type: 3}
    minigamePrefab: {fileID: 0}
  - nodeId: 1
    text: "Klokken er 18:15.\n\nDig og din ven Erik Frandsen, sidder og l\xE6ser
      igennem et dokument.\n\n\u201CNu skal vi finde ud af hvor der bliver kastet
      forsyninger.\u201D\n\nErik vender sig mod dig.\n\n\u201CDet skulle gerne v\xE6re
      p\xE5 linje 3 og linje 6.\u201D\n\n\u201CSe i bogen for at afkode ordene.\u201D"
    choices: []
    defaultTargetNodeId: 2
    voiceClip: {fileID: 8300000, guid: e9151ac6bdb8dca428dcd7743fd4c50d, type: 3}
    BackgroundImage: {fileID: 2800000, guid: 6de7144a943968140b5d93a562c827d1, type: 3}
    minigamePrefab: {fileID: 7416240185725632505, guid: 6a1ce9beeea46de438ece10a53cdffb5, type: 3}
  - nodeId: 2
    text: "I ankommer til kysten ved Eneb\xE6rodde, om natten.\n\r\nAlt er m\xF8rkt.\n\r\nFolk
      st\xE5r allerede klar.\n\r\nErik kigger p\xE5 dig.\n\r\n\u201CV\xE6r klar med
      lygten, n\xE5r vi h\xF8rer flyet\u201D\r\n\r"
    choices: []
    defaultTargetNodeId: 3
    voiceClip: {fileID: 8300000, guid: a4934e52bedf4f5448b40ed1e4f1a619, type: 3}
    BackgroundImage: {fileID: 2800000, guid: dcaa5ab24da5a2f4182072d2d034ab24, type: 3}
    minigamePrefab: {fileID: 0}
  - nodeId: 3
    text: "En times tid senere er folk begyndt at blive ansp\xE6ndte.\_\n\nS\xE5
      h\xF8res det.\n\nEt fly.\n\nEn britisk Stirling flyver lavt hen over jer.\n\n\u201CSkynd
      dig at morse <b>R-A-Y</b> til flyet!\u201D \r"
    choices: []
    defaultTargetNodeId: 4
    voiceClip: {fileID: 8300000, guid: 72cd5a2fa61a5cb4a9eae471462859d7, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 7416240185725632505, guid: 63581926aea032c46943b25ac5c3de79, type: 3}
  - nodeId: 4
    text: "Senere samme nat.\n\r\nDu bliver f\xF8rt til en g\xE5rd.\n\r\nEn mand
      st\xE5r i m\xF8rket.\n\r\n\u201CDu klarede det.\u201D\n\r\nHan tr\xE6der frem
      og introducerer sig.\n\r\n\u201CPeter Carlsen, britisk S.O.E agent.\u201D\r\n\r\r"
    choices: []
    defaultTargetNodeId: 5
    voiceClip: {fileID: 8300000, guid: 656d93ec034c89748b67bec084c528c8, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 5
    text: "Han l\xE6gger et kort frem.\n\r\n\u201CDenne magnetmine vi fik fra England,
      den skal bruges.\u201D\n\r\nHan peger.\n\r\n\u201COdense havn. Ved skibsv\xE6rftet.\u201D\n\r\n\u201CTyskerne
      er ved at bygge skibet Linz om til en minel\xE6gger.\u201D\n\r\nPeter vender
      sig mod dig."
    choices: []
    defaultTargetNodeId: 6
    voiceClip: {fileID: 8300000, guid: 3fbd8df7865c4274d97fb3d309c50124, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 6
    text: "\u201CJeg kan forst\xE5 at du arbejder som elektriker p\xE5 skibsv\xE6rftet?\u201D\n\nPeter
      kigger p\xE5 dig med et alvorligt blik.\n\r\n\u201CDu skal ind og plante minen
      p\xE5 skibet.\u201D\n\r\nDu nikker en anelse nerv\xF8st.\n\r\nDu fort\xE6ller,
      at det nok er bedst at g\xF8re ved vagtskiftet klokken 13:00.\r\n"
    choices: []
    defaultTargetNodeId: 7
    voiceClip: {fileID: 8300000, guid: 575d0cf5f3f58cf4dbbfe25427133089, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 7
    text: "N\xE6ste dag, p\xE5 Odense Havn.\n\r\nLuften er tung og kold.\n\r\nForan
      dig ligger skibet, Linz.\n\r\nErik st\xE5r t\xE6t ved siden af dig.\n\r\n\u201CDen
      sejler fra havnen om et par dage.\" \n\r\n\u201CDet er vigtigt at den ikke
      forlader havnen.\u201D\n\r\nErik r\xE6kker dig tasken.\n\r\n\u201CDet op til
      dig nu\u201D \r\n\r\n"
    choices: []
    defaultTargetNodeId: 8
    voiceClip: {fileID: 8300000, guid: f0883238d3a6e3d45a679057ac168928, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 8
    text: "Du er kommet igennem vagt porten til v\xE6rftet.\n\r\nNerv\xF8st og langsomt
      n\xE6rmer du dig landgangen til Linz.\n\r\nMen noget er anderledes. \n\nDer
      er flere vagter end i g\xE5r. \n\nDu ser en tysk officer gestikulerer ved landgangen.\n\r\nKlokken
      er 12:50, vagtskiftet er om lidt.\n\r\nHvad g\xF8r du nu?\r\n"
    choices:
    - id: 
      label: "L\xE6g tasken under en b\xE6nk i omkl\xE6dningsrummet"
      targetNodeId: 9.A
    - id: 
      label: "Fors\xF8g alligevel \u2014 vagtskiftet er om lidt "
      targetNodeId: 9.B
    defaultTargetNodeId: 9
    voiceClip: {fileID: 8300000, guid: 929d4e6a8b24e5a418ed980131141867, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 9.A
    text: "Du s\xE6tter tasken fra dig under en b\xE6nk i omkl\xE6dningsrummet. \n\r\nSamme
      aften ringer du til Erik. \n\n\"Det kunne ikke lade sig g\xF8re i dag.\"\r\n\nEn
      pause i r\xF8ret.\n\r\n\"Jamen s\xE5 skal det sgu ogs\xE5 v\xE6re i morgen.\"\n
      \n\"Linz er planlagt til at sejle i overmorgen.\"\r\n"
    choices: []
    defaultTargetNodeId: 10
    voiceClip: {fileID: 8300000, guid: 885e9198c8d4a7944bf18a894a875392, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 9.B
    text: "Halvvejs op ad landgangen.\n\r\nEn vagt vender sig.\n\r\n\"Halt. Was haben
      Sie da?\"\n\r\nDit hjerte stopper op.\n\r\nDu s\xE6tter tasken roligt ned.
      \n\n\xC5bner den. Viser ham ledningerne.\n\r\nVagten tager et hurtig kig ned
      i tasken.\n\r\nS\xE5 vinker han dig videre."
    choices: []
    defaultTargetNodeId: 9.B.A
    voiceClip: {fileID: 8300000, guid: 84d23d985d1118d48a909d68a36470b4, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 9.B.A
    text: "Heldigvis s\xE5 han ikke minen, der var under ledningerne.\n\r\nVagtskiftet
      kl. 13 \u2013 Men noget er galt, der er flere vagter end normalt.\n\r\nDet
      kan ikke lade sig g\xF8re. \n\nIkke i dag.\n\r\nDu g\xE5r tilbage til omkl\xE6dningsrummet
      og gemmer tasken.\n\r\n\r\n\r\n"
    choices: []
    defaultTargetNodeId: 9.B.B
    voiceClip: {fileID: 8300000, guid: 4d9da1c4e88b42e45b8df3bbb4c79c56, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 9.B.B
    text: "Samme aften ringer du til Erik.\n   \n\"Det kunne ikke lade sig g\xF8re.\" 
      \n\nEn lang pause i r\xF8ret.  \n\n\"Jamen s\xE5 skal det sgu ogs\xE5 v\xE6re
      i morgen.\"\n\n\"Linz er planlagt til at sejle i overmorgen.\""
    choices: []
    defaultTargetNodeId: 10
    voiceClip: {fileID: 8300000, guid: 669c20bd9a5fb2641bb8bcef35594757, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 10
    text: "Tidlig n\xE6ste morgen. \n\r\nDu ikl\xE6der dig din kedeldragt.\n\r\nTil
      din lettelse er tasken hvor du efterlod den.\n\r\nDu g\xE5r om bord p\xE5 Linz
      og placerer tasken i et rel\xE6 skab, indtil vagtskiftet.\n\r\nKl. 10:00, sker
      noget uventet.\n\r\nEn stor stab af tyske marinere str\xF8mmer om bord."
    choices: []
    defaultTargetNodeId: 11
    voiceClip: {fileID: 8300000, guid: 721119a19729bdf419422be406bd51c3, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 11
    text: "De \xE5bner skabe. L\xF8fter presenninger. Tjekker rum.\n\r\nDu ser nerv\xF8st
      til, imens de vender hver en sten.\n\r\nMirakul\xF8st er der ingen, der kigger
      i rel\xE6 skabet.  \r\n\r\nDa der igen er ro p\xE5, \xE5bner du skabet.\n\r\nFinder
      spr\xE6ngladningen frem.\n\r\nDine h\xE6nder ryster.\r\n"
    choices: []
    defaultTargetNodeId: 12
    voiceClip: {fileID: 8300000, guid: 5fa63459a75e6954ba9ca0ea0b5c0419, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 12
    text: "Du f\xE5r firet spr\xE6ngstoffet med magneter ned p\xE5 siden af skibet.\n\r\nNu
      g\xE6lder det om at koncentrere sig.\n\n\rTimeren til minen, indstiller du
      til klokken 21:00.\n\r\nDu h\xF8rer et klik, da magneten s\xE6tter sig fast
      p\xE5 skibets side.\n\r\nDu \xE5nder lettet op. \n\r\nNu er det bare med at
      komme v\xE6k.\r\n\n\n\r"
    choices: []
    defaultTargetNodeId: 13
    voiceClip: {fileID: 8300000, guid: b235a14164b71014f8a39f4d211967c0, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 13
    text: "Om aftenen cykler du og Erik ned p\xE5 havnen for at overv\xE6re eksplosionen.\r\n\r\nS\xE5
      sl\xE5r klokken 21:00.\r\n\r\nAftenens stilhed brydes.\n\r\nEt dybt brag ryster
      vandet. \n\nEn s\xF8jle af vand og st\xE5l spr\xF8jter op langs skroget.\n\nLys
      flammer op p\xE5 d\xE6kket af Linz. \n\nDer h\xF8res r\xE5b og panik ved v\xE6rftet.\n"
    choices: []
    defaultTargetNodeId: 14
    voiceClip: {fileID: 8300000, guid: 60a913801ee3e974abc698eee4ac0bf3, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 14
    text: "Erik \xE5nder tungt ud ved din side.   \n\n\u201CHun sejler ingen steder
      nu.\u201D  \n\nI ser kort p\xE5 hinanden. \n\nIngen smil. \n\nIngen ord.  
      \n\nBare et nik.  "
    choices: []
    defaultTargetNodeId: 15
    voiceClip: {fileID: 8300000, guid: 6d2a5433eddda8946bfe330e846753d1, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 15
    text: "Skibet synker ikke \u2014 men skaden er alvorlig. \n\nOg det er nok. Endnu
      et slag i m\xF8rket. \n\nEndnu en forsinkelse for tyskerne.\n\r\nDen nat forsvinder
      I ind i byen igen, stille og ubem\xE6rket. \n\r\n"
    choices: []
    defaultTargetNodeId: 16
    voiceClip: {fileID: 8300000, guid: 203f966433be27048b110ee0a77ea67c, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
  - nodeId: 16
    text: "Men jeres handling bliver en lille del af noget st\xF8rre. \n\nSabotagen
      mod skibene, strejkerne, og uroen i Odense og andre byer er med til at t\xE6nde
      gnisten, der senere p\xE5 sommeren bryder ud i det, der bliver kendt som Augustopr\xF8ret
      \u2014 en b\xF8lge af \xE5ben modstand, der for alvor ryster bes\xE6ttelsesmagten."
    choices: []
    defaultTargetNodeId: 16
    voiceClip: {fileID: 8300000, guid: 9ff80523c15d8de41bd16c0555788fcf, type: 3}
    BackgroundImage: {fileID: 0}
    minigamePrefab: {fileID: 0}
