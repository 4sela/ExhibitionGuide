  nodes:
  - nodeId: 0
    text: "Odense, sommeren 1943.\n\r\nBes\xE6ttelsen har \xE6ndret sig.\r\nDet er
      ikke l\xE6ngere stille.\n\r\nStrejker. Sabotage. Rygter.\n\nOg England kaster
      forsyninger ned fra himlen. \n\r\nDu er ikke l\xE6ngere bare en tilskuer.\nDu
      er en del af modstandsbev\xE6gelsen.\n\r\nOg i aften\u2026 venter en besked
      fra BBC.\r"
    choices:
    - id: 1
      label: "Forts\xE6r"
      targetNodeId: 1
      conditionKey: 
      setVariableKey: 
      setVariableValue: 
    defaultTargetNodeId: 1
    autoAdvanceDelay: 0
    onEnterEvent: 
  - nodeId: 1
    text: "Klokken er 18:15.\r\nDig og din ven Erik sidder og lytter ved radioen.\r\nRadioen
      knitrer.\r\n\u201CEn hilsen til Niels.\r\n Bageren arbejder i nat.\u201D\r\nErik
      vender sig mod dig.\r\n\u201CDet er vores besked, f\xE5 afkodet den\u201D\r"
    choices: []
