    m_PersistentCalls:
      m_Calls: []
  m_text: "Du skal nu bruge en udstillingsgenstand fra museet til dette.\n\nFind
    dokumentet <i>\u201CTil arbejderne i Odense\u201D</i> i omr\xE5det Danmark Besat.\n\nL\xE6s
    <color=#ECD3AA>linje 3 og 6</color> i dokumentet, og find ord p\xE5 de to linjer
    der matcher med dem i <color=#ECD3AA>kodebogen</color>.  "
  m_isRightToLeft: 0
