--- !u!114 &518847736
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 518847734}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f4688fdb7df04437aeb418b961361dc5, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  m_Material: {fileID: 0}
  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Sommeren 1943 markerede et vendepunkt for den danske samarbejdspolitik.
    Allierede sejre ved Stalingrad og i Nordafrika styrkede modstandsviljen i Danmark.\n\r\nI
    Odense blev urolighederne forst\xE6rket den 28. juli 1943, da modstandsbev\xE6gelsen
    saboterede den tyske mineudl\xE6gger Linz p\xE5 Odenses st\xE5lskibsv\xE6rft.
    Aktionen bidrog til en b\xF8lge af strejker, idet den viste, at tyskerne var
    s\xE5rbare og dermed styrkede arbejdernes mod til \xE5ben modstand, som spredte
    sig fra v\xE6rftsarbejderne til store dele af byens befolkning.\n\r\nSituationen
    eskalerede i august. Tyske soldater optr\xE5dte mere aggressivt, hvilket f\xF8rte
    til sammenst\xF8d med civile, s\xE6rligt unge m\xE6nd.Den 18. august kulminerede
    urolighederne i en generalstrejke. Butikker, der blev opfattet som samarbejdende
    med tyskerne, blev raseret, og vreden ramte ogs\xE5 kvinder, der havde forhold
    til tyske soldater, som i samtiden blev omtalt \u201Ctyske feltmadresser\u201D.\n\r\nDet
    danske politi fors\xF8gte at genoprette ro og orden, men kontrollen var i praksis
    sv\xE6kket, og gaderne var pr\xE6get af uro og konfrontationer. Et af de m\xF8rkeste
    kapitler under opr\xF8ret i Odense fandt sted den 19. August. Tyske SS-politistyrker
    indsatte brutal magt og foretog massearrestationer. \n\r\nDokumentationen af
    disse mishandlinger, i form af fotografier af forsl\xE5ede modstandsfolk, blev
    et afg\xF8rende propaganda-v\xE6rkt\xF8j for modstandsbev\xE6gelsen. Billederne
    fjernede enhver rest af illusionen om den humanit\xE6re bes\xE6ttelse og forst\xE6rkede
    hadet mod tyskerne i hele landet.\r\nFors\xF8get p\xE5 at genoprette ro og orden
    ses tydeligt i samtidige dokumenter. I en meddelelse \u201CTil arbejderne i Odense\u201D
    fra Arbejdernes F\xE6llesorganisation den 20. august 1943 blev de strejkende
    opfordret til at genoptage arbejdet. Dokumentet viser, hvordan fagbev\xE6gelsens
    ledelse fors\xF8gte at d\xE6mpe urolighederne og advarede mod rygtesmede og uansvarlige
    elementer.\n\r\nUrolighederne i Odense og andre byer f\xF8rte til en politisk
    krise. Den tyske rigsbefuldm\xE6gtigede Werner Best kr\xE6vede blandt andet d\xF8dsstraf
    for sabotage, hvilket den danske regering n\xE6gtede at acceptere. Den 29. august
    1943 tr\xE5dte regeringen tilbage, samarbejdspolitikken oph\xF8rte, og tyskerne
    indf\xF8rte milit\xE6r undtagelsestilstand. Herefter blev bes\xE6ttelsen v\xE6sentligt
    sk\xE6rpet, og modstanden udviklede sig til en mere \xE5ben konfrontation med
    tyskerne.\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 83361745857f09d44ac9fe0419f55ead, type: 2}
